###############################################################################
# Pi Engine Configuration
#
# Copy this file to:
#   config.toml
#
# Values provided on the command line override values in this file.
###############################################################################

###############################################################################
# Precision
###############################################################################

# Number of decimal digits to calculate.
digits = 1000000

###############################################################################
# Threading
###############################################################################

# Number of worker threads.
# 0 = Automatically use all available hardware threads.
threads = 0

###############################################################################
# Checkpoint
###############################################################################

# Enable periodic checkpoints.
checkpoint = true

# Save checkpoint every N seconds.
checkpoint_interval = 300

###############################################################################
# Memory
###############################################################################

# Attempt to use Huge Pages if supported.
huge_pages = true

###############################################################################
# Out-of-Core Storage
###############################################################################

# Enable disk-backed storage for large computations.
out_of_core = true

# Compression algorithm.
# Current planned values:
#   "lz4"
compression = "lz4"

###############################################################################
# Progress
###############################################################################

# Progress update interval (milliseconds).
progress_interval = 500

###############################################################################
# Output
###############################################################################

# Output file.
output = "pi.txt"

###############################################################################
# Resume
###############################################################################

# Automatically resume from the latest checkpoint if available.
resume = true